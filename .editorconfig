# ==============================================================================
# FILE:        .editorconfig
# CREATED:     2025-11-20
# UPDATED:     2026-04-29 — Added C# 14 + .NET 10 rules, missing CA rules,
#                            section cleanup, doc links
# RESPONSIBLE: Kirsten Kluge / Spectara
# PROJECTS:    .NET 10, C# 14, Revela Static Site Generator
# ==============================================================================
#
# Note: TreatWarningsAsErrors=true (Directory.Build.props) means every `warning`
#       severity here will FAIL the build. Severities are deliberate.
# ==============================================================================

# ===== COMMON SETTINGS =====

root = true

[*]
charset = utf-8
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

# ===== FILE EXTENSION SETTINGS =====

[*.sln]
indent_style = tab

[*.{csproj,vbproj,vcxproj.filters,proj,projitems,shproj}]
indent_size = 2

[*.{xml,config,props,targets,nuspec,resx,ruleset,vsixmanifest,vsct}]
indent_size = 2

[*.{json,json5,webmanifest}]
indent_size = 2

[*.{yml,yaml}]
indent_size = 2

[*.{md,mdx}]
trim_trailing_whitespace = false

[*.{htm,html,js,jsm,ts,tsx,cjs,cts,ctsx,mjs,mts,mtsx,css,sass,scss,less,pcss,svg,vue}]
indent_size = 2

[*.{cmd,bat}]
end_of_line = crlf

[*.sh]
end_of_line = lf

[Makefile]
indent_style = tab

# ===== .NET CODE STYLE & ANALYZER RULES =====

[*.{cs,csx,cake,vb,vbx}]
# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules
dotnet_analyzer_diagnostic.severity = warning

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/qualification
# UPDATED: Modern C# style without 'this.' qualification (C# 10+ standard)
dotnet_style_qualification_for_field = false:warning
dotnet_style_qualification_for_property = false:warning
dotnet_style_qualification_for_method = false:warning
dotnet_style_qualification_for_event = false:warning

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/predefined-type-preferences
dotnet_style_predefined_type_for_locals_parameters_members = true:warning
dotnet_style_predefined_type_for_member_access = true:warning

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/accessibility-modifiers
# UPDATED: Interfaces don't need accessibility modifiers on members
dotnet_style_require_accessibility_modifiers = for_non_interface_members:warning

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/modifier-order
csharp_preferred_modifier_order = public,private,protected,internal,static,extern,new,virtual,abstract,sealed,override,readonly,unsafe,volatile,async:warning
visual_basic_preferred_modifier_order = Partial,Default,Private,Protected,Public,Friend,NotOverridable,Overridable,MustOverride,Overloads,Overrides,MustInherit,NotInheritable,Static,Shared,Shadows,ReadOnly,WriteOnly,Dim,Const,WithEvents,Widening,Narrowing,Custom,Async:warning

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/readonly
dotnet_style_readonly_field = true:warning

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/parentheses
dotnet_style_parentheses_in_arithmetic_binary_operators = always_for_clarity:warning
dotnet_style_parentheses_in_relational_binary_operators = always_for_clarity:warning
dotnet_style_parentheses_in_other_binary_operators = always_for_clarity:warning
dotnet_style_parentheses_in_other_operators = never_if_unnecessary:warning

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/object-and-collection-initializers
dotnet_style_object_initializer = true:warning
dotnet_style_collection_initializer = true:warning

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/explicit-tuple-names
dotnet_style_explicit_tuple_names = true:warning
dotnet_style_prefer_inferred_tuple_names = true:warning
dotnet_style_prefer_inferred_anonymous_type_member_names = true:warning

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/auto-properties
dotnet_style_prefer_auto_properties = true:warning

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/conditional-expression
dotnet_style_prefer_conditional_expression_over_assignment = false:suggestion
dotnet_diagnostic.IDE0045.severity = suggestion
dotnet_style_prefer_conditional_expression_over_return = false:suggestion
dotnet_diagnostic.IDE0046.severity = suggestion

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/compound-assignment
dotnet_style_prefer_compound_assignment = true:warning

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/interpolated-strings
dotnet_style_prefer_simplified_interpolation = true:warning

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/boolean-expressions
dotnet_style_prefer_simplified_boolean_expressions = true:warning

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/null-checking
dotnet_style_coalesce_expression = true:warning
dotnet_style_null_propagation = true:warning
dotnet_style_prefer_is_null_check_over_reference_equality_method = true:warning

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/operator-placement
dotnet_style_operator_placement_when_wrapping = end_of_line:warning

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/quality-rules/ca1716
# CA1716: Identifiers should not match keywords (in any .NET language)
# Reason: Prevents accidentally choosing names that conflict with VB/F# keywords.
# Excluded: "Shared" (legitimate test fixture name)
dotnet_diagnostic.CA1716.severity = warning
dotnet_diagnostic.CA1716.excluded_symbol_names = Shared

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/quality-rules/ca1031
# CA1031: Do not catch general exception types
# Reason: Top-level handlers need to catch all exceptions
dotnet_diagnostic.CA1031.severity = suggestion

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/quality-rules/ca1062
# CA1062: Validate arguments of public methods
# Reason: Nullable reference types (C# 14) handle this validation
dotnet_diagnostic.CA1062.severity = suggestion

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/quality-rules/ca2007
# CA2007: Consider calling ConfigureAwait on the awaited task
# Reason: Not needed in applications (only libraries), .NET 10 handles this
dotnet_diagnostic.CA2007.severity = none

# ===== C# STYLE RULES =====

[*.{cs,csx,cake}]
# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/var-preferences
csharp_style_var_for_built_in_types = true:warning
csharp_style_var_when_type_is_apparent = true:warning
csharp_style_var_elsewhere = true:warning

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/expression-bodied-members
# UPDATED: Relaxed to suggestion - allow both styles
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_constructors = when_on_single_line:suggestion
csharp_style_expression_bodied_operators = when_on_single_line:suggestion
csharp_style_expression_bodied_properties = when_on_single_line:suggestion
csharp_style_expression_bodied_indexers = when_on_single_line:suggestion
csharp_style_expression_bodied_accessors = when_on_single_line:suggestion
csharp_style_expression_bodied_lambdas = when_on_single_line:suggestion
csharp_style_expression_bodied_local_functions = when_on_single_line:suggestion

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/pattern-matching
csharp_style_pattern_matching_over_is_with_cast_check = true:warning
csharp_style_pattern_matching_over_as_with_null_check = true:warning
csharp_style_prefer_switch_expression = true:warning
csharp_style_prefer_pattern_matching = true:warning
csharp_style_prefer_not_pattern = true:warning

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/inlined-variable-declaration
csharp_style_inlined_variable_declaration = true:warning

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/default-expression
csharp_prefer_simple_default_expression = true:warning

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/pattern-local-over-anonymous-function
csharp_style_pattern_local_over_anonymous_function = true:warning

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/deconstructed-variable-declaration
csharp_style_deconstructed_variable_declaration = true:warning

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/index-and-range-operator
csharp_style_prefer_index_operator = true:warning
csharp_style_prefer_range_operator = true:warning

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/implicit-object-creation
csharp_style_implicit_object_creation_when_type_is_apparent = true:warning

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/throw-expression
csharp_style_throw_expression = true:warning

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/conditional-delegate-call
csharp_style_conditional_delegate_call = true:warning

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/braces
csharp_prefer_braces = true:warning

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/simple-using-statement
csharp_prefer_simple_using_statement = true:suggestion
dotnet_diagnostic.IDE0063.severity = suggestion

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/using-directive-placement
# UPDATED: C# 10+ Standard (Microsoft Best Practice with file-scoped namespaces)
csharp_using_directive_placement = outside_namespace:warning

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/static-local-function
csharp_prefer_static_local_function = true:warning

# ===== C# 12-14 NEW FEATURES =====

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/ide0290
# Prefer primary constructors (C# 12)
csharp_style_prefer_primary_constructors = true:suggestion
dotnet_diagnostic.IDE0290.severity = suggestion

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/ide0170
# Simplify property pattern (C# 10+)
csharp_style_prefer_extended_property_pattern = true:suggestion
dotnet_diagnostic.IDE0170.severity = suggestion

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/ide0230
# Use UTF-8 string literals (C# 11+)
csharp_style_prefer_utf8_string_literals = true:suggestion
dotnet_diagnostic.IDE0230.severity = suggestion

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/ide0200
# Prefer method group conversion (C# 11+)
csharp_style_prefer_method_group_conversion = true:silent
dotnet_diagnostic.IDE0200.severity = silent

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/ide0210
# Prefer top-level statements (C# 9+)
csharp_style_prefer_top_level_statements = true:silent
dotnet_diagnostic.IDE0210.severity = silent

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/ide0300
# Use collection expressions (C# 12) — `[]` instead of `new List<>()` / `Array.Empty<>()`
dotnet_style_prefer_collection_expression = when_types_loosely_match:warning
dotnet_diagnostic.IDE0300.severity = warning
dotnet_diagnostic.IDE0301.severity = warning
dotnet_diagnostic.IDE0302.severity = warning
dotnet_diagnostic.IDE0303.severity = warning
dotnet_diagnostic.IDE0304.severity = warning
dotnet_diagnostic.IDE0305.severity = warning

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/ide0270
# Null check can be simplified (use `??` instead of `is null + throw`) — C# 11+
csharp_style_prefer_null_check_over_type_check = true:warning
dotnet_diagnostic.IDE0270.severity = warning

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/ide0330
# Prefer System.Threading.Lock over object lock (C# 13 / .NET 9+)
csharp_prefer_system_threading_lock = true:warning
dotnet_diagnostic.IDE0330.severity = warning

# ===== .NET 10 / C# 14 PERFORMANCE & API RULES =====

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/quality-rules/ca1311
# CA1311: Specify a culture for ToLower/ToUpper
# Reason: Aligns with our InvariantCulture convention
dotnet_diagnostic.CA1311.severity = warning

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/quality-rules/ca1851
# CA1851: Possible multiple enumerations of IEnumerable
# Reason: Performance — avoid silent re-enumeration
dotnet_diagnostic.CA1851.severity = warning

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/quality-rules/ca1852
# CA1852: Seal internal types
# Reason: Aligns with our "sealed by default" convention
dotnet_diagnostic.CA1852.severity = warning

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/quality-rules/ca1859
# CA1859: Use concrete types when possible for improved performance
# Reason: Helps DI internals and hot paths
dotnet_diagnostic.CA1859.severity = suggestion

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/quality-rules/ca1860
# CA1860: Avoid using `Enumerable.Any()` extension method
# Reason: `.Count > 0` / `.Length > 0` is faster on collections
dotnet_diagnostic.CA1860.severity = warning

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/quality-rules/ca1865
# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/quality-rules/ca1866
# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/quality-rules/ca1867
# CA1865/CA1866/CA1867: Use char overload of StartsWith/EndsWith/IndexOf
# Reason: Faster than string overload for single-char checks
# Aligns with our convention: `StartsWith('-')` not `StartsWith("-", StringComparison.Ordinal)`
dotnet_diagnostic.CA1865.severity = warning
dotnet_diagnostic.CA1866.severity = warning
dotnet_diagnostic.CA1867.severity = warning

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/quality-rules/ca1869
# CA1869: Cache and reuse `JsonSerializerOptions` instances
# Reason: We have many JSON configs (project.json, site.json, manifest.json) — caching matters
dotnet_diagnostic.CA1869.severity = warning

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/quality-rules/ca1873
# CA1873: Avoid potentially expensive logging
# Reason: Enforces our LoggerMessage source generator convention
# (warns when logger.LogInformation($"...") interpolation is used)
dotnet_diagnostic.CA1873.severity = warning

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/quality-rules/ca2264
# CA2264: Do not pass a non-nullable value to ArgumentNullException.ThrowIfNull
# Reason: Modern null-check pattern (.NET 8+)
dotnet_diagnostic.CA2264.severity = warning

# ===== TYPE & API SAFETY (referenced by Copilot conventions) =====
# These rules are explicitly mentioned in .github/copilot-instructions.md
# under "Code Quality — Fix, Don't Suppress". Enforced as warnings to make
# the convention machine-checked, not just documented.

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/quality-rules/ca1054
# CA1054: URI parameters should not be strings
# Reason: Use `Uri?` for URL parameters — System.Text.Json deserializes Uri natively
dotnet_diagnostic.CA1054.severity = warning

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/quality-rules/ca1055
# CA1055: URI return values should not be strings
dotnet_diagnostic.CA1055.severity = warning

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/quality-rules/ca1056
# CA1056: URI properties should not be strings
# Reason: Use `Uri?` for URL properties
dotnet_diagnostic.CA1056.severity = warning

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/quality-rules/ca1002
# CA1002: Do not expose generic lists
# Reason: Expose `IReadOnlyList<T>` instead of `List<T>` from public APIs
dotnet_diagnostic.CA1002.severity = warning

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/quality-rules/ca2227
# CA2227: Collection properties should be read-only
# Reason: `IReadOnlyDictionary<K,V>` / `IReadOnlyList<T>` instead of mutable setter
dotnet_diagnostic.CA2227.severity = warning

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/quality-rules/ca1819
# CA1819: Properties should not return arrays
# Reason: Use `IReadOnlyList<T>` — array properties allow mutation of internal state
dotnet_diagnostic.CA1819.severity = warning

# ===== UNNECESSARY CODE DETECTION =====
# Rules that flag dead code: unused parameters, unread values,
# stale #pragma suppressions, and ignored return values.

[*.{cs,csx,cake,vb,vbx}]
# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/ide0060
# IDE0060: Remove unused parameters
dotnet_code_quality_unused_parameters = all:warning

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/ide0079
# IDE0079: Remove stale `#pragma warning disable` / `[SuppressMessage]` that no longer suppress anything
dotnet_remove_unnecessary_suppression_exclusions = none:warning

[*.{cs,csx,cake}]
# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/ide0058
# IDE0058: Expression value is never used (e.g. `int.Parse(s);` — should be `_ = int.Parse(s);`)
csharp_style_unused_value_expression_statement_preference = discard_variable:suggestion
dotnet_diagnostic.IDE0058.severity = suggestion

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/ide0059
# IDE0059: Unnecessary value assignment (variable assigned but never read)
csharp_style_unused_value_assignment_preference = discard_variable:suggestion
dotnet_diagnostic.IDE0059.severity = suggestion

# ===== FORMATTING RULES =====

[*.{cs,csx,cake,vb,vbx}]
# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/formatting-rules
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false
dotnet_style_namespace_match_folder = true:suggestion
dotnet_diagnostic.IDE0130.severity = suggestion

[*.{cs,csx,cake}]
# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/formatting-rules#new-line-options
csharp_new_line_before_open_brace = all
csharp_new_line_before_else = true
csharp_new_line_before_catch = true
csharp_new_line_before_finally = true
csharp_new_line_before_members_in_object_initializers = true
csharp_new_line_before_members_in_anonymous_types = true
csharp_new_line_between_query_expression_clauses = true

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/formatting-rules#indentation-options
csharp_indent_case_contents = true
csharp_indent_switch_labels = true
csharp_indent_labels = no_change
csharp_indent_block_contents = true
csharp_indent_braces = false
csharp_indent_case_contents_when_block = false

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/formatting-rules#spacing-options
csharp_space_after_cast = false
csharp_space_after_keywords_in_control_flow_statements = true
csharp_space_between_parentheses = false
csharp_space_before_colon_in_inheritance_clause = true
csharp_space_after_colon_in_inheritance_clause = true
csharp_space_around_binary_operators = before_and_after
csharp_space_between_method_declaration_parameter_list_parentheses = false
csharp_space_between_method_declaration_empty_parameter_list_parentheses = false
csharp_space_between_method_declaration_name_and_open_parenthesis = false
csharp_space_between_method_call_parameter_list_parentheses = false
csharp_space_between_method_call_empty_parameter_list_parentheses = false
csharp_space_between_method_call_name_and_opening_parenthesis = false
csharp_space_after_comma = true
csharp_space_before_comma = false
csharp_space_after_dot = false
csharp_space_before_dot = false
csharp_space_after_semicolon_in_for_statement = true
csharp_space_before_semicolon_in_for_statement = false
csharp_space_around_declaration_statements = false
csharp_space_before_open_square_brackets = false
csharp_space_between_empty_square_brackets = false
csharp_space_between_square_brackets = false

# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/formatting-rules#wrap-options
csharp_preserve_single_line_statements = false
csharp_preserve_single_line_blocks = true

# ===== NAMESPACE STYLE =====

[*.{cs,csx,cake}]
# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/ide0161
# IDE0161: Use file-scoped namespace declarations (C# 10+)
# Reason: Reduces nesting, matches modern Microsoft sample code style
csharp_style_namespace_declarations = file_scoped:warning
dotnet_diagnostic.IDE0161.severity = warning

# ===== BOOLEAN & NULL CHECKING (Revela Custom Convention) =====
# Documentation-only — no automatic .editorconfig rule available.
# Enforced via code review and the `review-code` skill.
#
# CRITICAL: Use explicit pattern matching instead of the `!` operator.
# Reason: The `!` operator is overloaded in modern C#:
#   1. Logical negation:        if (!condition)
#   2. Null-forgiving operator: var x = value!;
#   3. Pattern negation:        if (x is not null)
# This ambiguity creates confusion and potential bugs.
#
# ✅ PREFER (explicit pattern matching):
#   - if (value is true) { }
#   - if (value is false) { }
#   - if (value is not true) { }    // false OR null (for bool?)
#   - if (value is null) { }
#   - if (value is not null) { }
#
# ❌ AVOID (ambiguous `!` operator):
#   - if (!value) { }               // Hard to distinguish from null-forgiving
#   - if (value != null) { }        // Use 'is not null' instead
#
# Note: `!` is still allowed for null-forgiving operator when unavoidable:
#   var name = person.Name!;        // Compiler hint — this is safe

# ===== .NET NAMING RULES =====

[*.{cs,csx,cake,vb,vbx}]
# https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/naming-rules

# Define naming styles
dotnet_naming_style.camel_case_style.capitalization = camel_case

dotnet_naming_style.pascal_case_style.capitalization = pascal_case

dotnet_naming_style.prefix_interface_with_i_style.capitalization = pascal_case
dotnet_naming_style.prefix_interface_with_i_style.required_prefix = I

dotnet_naming_style.prefix_type_parameters_with_t_style.capitalization = pascal_case
dotnet_naming_style.prefix_type_parameters_with_t_style.required_prefix = T

# CRITICAL: Constants (const fields) → PascalCase (NO underscore!)
dotnet_naming_symbols.constant_fields.applicable_kinds = field
dotnet_naming_symbols.constant_fields.required_modifiers = const
dotnet_naming_rule.constant_fields_must_be_pascal_case.symbols = constant_fields
dotnet_naming_rule.constant_fields_must_be_pascal_case.style = pascal_case_style
dotnet_naming_rule.constant_fields_must_be_pascal_case.severity = warning

# CRITICAL: Static readonly fields → PascalCase (NO underscore!)
dotnet_naming_symbols.static_readonly_fields.applicable_kinds = field
dotnet_naming_symbols.static_readonly_fields.required_modifiers = static, readonly
dotnet_naming_rule.static_readonly_fields_must_be_pascal_case.symbols = static_readonly_fields
dotnet_naming_rule.static_readonly_fields_must_be_pascal_case.style = pascal_case_style
dotnet_naming_rule.static_readonly_fields_must_be_pascal_case.severity = warning

# CRITICAL: Private instance fields → camelCase (NO underscore prefix!)
# Reason: Modern C# style, better readability, matches Microsoft's own codebase
# This actively PREVENTS _camelCase which is a legacy C++/ReSharper anti-pattern
# Build will FAIL with IDE1006 if underscore prefix is used
# Example: ✅ private readonly HttpClient httpClient; ❌ private readonly HttpClient _httpClient;
dotnet_naming_symbols.private_instance_fields.applicable_kinds = field
dotnet_naming_symbols.private_instance_fields.applicable_accessibilities = private
dotnet_naming_rule.private_instance_fields_must_be_camel_case.symbols = private_instance_fields
dotnet_naming_rule.private_instance_fields_must_be_camel_case.style = camel_case_style
dotnet_naming_rule.private_instance_fields_must_be_camel_case.severity = warning

# Public/Protected fields disallowed (use properties!)
dotnet_naming_symbols.public_protected_fields.applicable_accessibilities = public, protected, protected_internal
dotnet_naming_symbols.public_protected_fields.applicable_kinds = field
dotnet_naming_rule.public_protected_fields_disallowed.symbols = public_protected_fields
dotnet_naming_rule.public_protected_fields_disallowed.style = pascal_case_style
dotnet_naming_rule.public_protected_fields_disallowed.severity = error

# Types (class, struct, enum, delegate) → PascalCase
dotnet_naming_symbols.types.applicable_kinds = class, struct, enum, delegate
dotnet_naming_rule.types_must_be_pascal_case.symbols = types
dotnet_naming_rule.types_must_be_pascal_case.style = pascal_case_style
dotnet_naming_rule.types_must_be_pascal_case.severity = warning

# Members (method, property, event) → PascalCase
dotnet_naming_symbols.members.applicable_kinds = method, property, event
dotnet_naming_rule.members_must_be_pascal_case.symbols = members
dotnet_naming_rule.members_must_be_pascal_case.style = pascal_case_style
dotnet_naming_rule.members_must_be_pascal_case.severity = warning

# Interfaces → IPascalCase
dotnet_naming_symbols.interfaces.applicable_kinds = interface
dotnet_naming_rule.interfaces_must_be_prefixed_with_i.symbols = interfaces
dotnet_naming_rule.interfaces_must_be_prefixed_with_i.style = prefix_interface_with_i_style
dotnet_naming_rule.interfaces_must_be_prefixed_with_i.severity = warning

# Type parameters → TPascalCase
dotnet_naming_symbols.type_parameters.applicable_kinds = type_parameter
dotnet_naming_rule.type_parameters_must_be_prefixed_with_t.symbols = type_parameters
dotnet_naming_rule.type_parameters_must_be_prefixed_with_t.style = prefix_type_parameters_with_t_style
dotnet_naming_rule.type_parameters_must_be_prefixed_with_t.severity = warning

# Parameters & Local variables → camelCase (NO underscore!)
dotnet_naming_symbols.parameters_and_locals.applicable_kinds = parameter, local
dotnet_naming_rule.parameters_and_locals_must_be_camel_case.symbols = parameters_and_locals
dotnet_naming_rule.parameters_and_locals_must_be_camel_case.style = camel_case_style
dotnet_naming_rule.parameters_and_locals_must_be_camel_case.severity = warning

