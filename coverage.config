<?xml version="1.0" encoding="utf-8"?>
<!--
  Microsoft Code Coverage settings for Revela.

  Filters coverage to measure only our application logic,
  excluding framework wiring, test assemblies, and external code.

  Usage:
    dotnet test -​-coverage -​-coverage-settings coverage.config -​-coverage-output-format cobertura
    
  Reference:
    https://github.com/microsoft/codecoverage/blob/main/docs/configuration.md
-->
<Configuration>
  <!-- Don't include test assemblies in coverage (default: false for MTP) -->
  <IncludeTestAssembly>false</IncludeTestAssembly>

  <!-- Exclude assemblies without source files (NuGet packages) -->
  <ExcludeAssembliesWithoutSources>MissingAll</ExcludeAssembliesWithoutSources>

  <!-- Skip auto-implemented properties (Config DTOs: get; init;) -->
  <SkipAutoProperties>true</SkipAutoProperties>

  <!-- Output in Cobertura format for CI/reporting tools -->
  <Format>cobertura</Format>

  <CodeCoverage>
    <!--
      Module filter: Only include our assemblies.
      Regex syntax (ECMAScript). Must match module path.
    -->
    <ModulePaths>
      <Include>
        <ModulePath>.*Spectara\.Revela\..*</ModulePath>
      </Include>
      <Exclude>
        <!-- Test assemblies -->
        <ModulePath>.*\.Tests\.dll$</ModulePath>
        <ModulePath>.*IntegrationTests\.dll$</ModulePath>
        <ModulePath>.*Tests\.Shared\.dll$</ModulePath>
      </Exclude>
    </ModulePaths>

    <!--
      Function filter: Exclude CLI wiring methods that only call
      System.CommandLine framework code (new Command, SetAction, etc.)
    -->
    <Functions>
      <Exclude>
        <!-- Create() methods on all Command classes: pure framework wiring -->
        <Function>^Spectara\.Revela\..*Command\.Create\(\)$</Function>

        <!-- Plugin lifecycle methods: only call IServiceCollection/IConfiguration -->
        <Function>^Spectara\.Revela\..*Plugin\.ConfigureServices\(.*\)$</Function>
        <Function>^Spectara\.Revela\..*Plugin\.ConfigureConfiguration\(.*\)$</Function>
        <Function>^Spectara\.Revela\..*Plugin\.GetCommands\(.*\)$</Function>

        <!-- DI registration: AddXxxFeature, AddRevelaCommands, etc. -->
        <Function>^Spectara\.Revela\..*ServiceCollectionExtensions\..*</Function>

        <!-- Host builder extensions: AddRevelaConfiguration, UseRevelaCommands -->
        <Function>^Spectara\.Revela\.Cli\.Hosting\.HostBuilderExtensions\..*</Function>
        <Function>^Spectara\.Revela\.Cli\.Hosting\.HostExtensions\..*</Function>
      </Exclude>
    </Functions>

    <!--
      Attribute filter: Exclude code decorated with these attributes.
      [ExcludeFromCodeCoverage] can be used for additional one-off exclusions.
    -->
    <Attributes>
      <Exclude>
        <Attribute>^System\.Diagnostics\.CodeAnalysis\.ExcludeFromCodeCoverageAttribute$</Attribute>
        <Attribute>^System\.CodeDom\.Compiler\.GeneratedCodeAttribute$</Attribute>
        <Attribute>^System\.Diagnostics\.DebuggerHiddenAttribute$</Attribute>
        <Attribute>^System\.Diagnostics\.DebuggerNonUserCodeAttribute$</Attribute>
      </Exclude>
    </Attributes>

    <!--
      Source file filter: Exclude auto-generated files.
    -->
    <Sources>
      <Exclude>
        <Source>.*\.g\.cs$</Source>
        <Source>.*AssemblyInfo\.cs$</Source>
      </Exclude>
    </Sources>
  </CodeCoverage>
</Configuration>
